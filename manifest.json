{
  "version": "0.1.0",
  "architecture": {
    "tiers": ["brand", "core", "product", "system"],
    "flow": "brand → core → product → system",
    "uiTier": "system",
    "internalTiers": ["brand", "core", "product"]
  },
  "brands": {
    "compsych": "tokens/brand/compsych.json",
    "brandB": "tokens/brand/brand-b.json",
    "brandC": "tokens/brand/brand-c.json"
  },
  "products": {
    "gro": "tokens/product/gro.json",
    "crc": "tokens/product/crc.json",
    "gn": "tokens/product/gn.json",
    "fmla": "tokens/product/fmla.json"
  },
  "tokens": {
    "core": "tokens/core.json",
    "system": "tokens/system.json"
  },
  "outputs": {
    "note": "Generated by `npm run build:tokens`. Paths below are documentation — the files themselves are gitignored under tokens/dist/. One bundle per (brand × product) combination; each bundle contains three files (CSS, SCSS, TS).",
    "bundleDir": "tokens/dist/{brand}-{product}/",
    "files": [
      { "name": "tokens.css", "format": "css/variables", "consumer": "Angular (via global stylesheet)" },
      { "name": "tokens.scss", "format": "scss/variables", "consumer": "Angular (alternative to CSS)" },
      { "name": "tokens.ts", "format": "typescript/sys-nested", "consumer": "React Native" }
    ],
    "combinations": [
      "tokens/dist/compsych-gro/",
      "tokens/dist/compsych-crc/",
      "tokens/dist/compsych-gn/",
      "tokens/dist/compsych-fmla/",
      "tokens/dist/brand-b-gro/",
      "tokens/dist/brand-b-crc/",
      "tokens/dist/brand-b-gn/",
      "tokens/dist/brand-b-fmla/",
      "tokens/dist/brand-c-gro/",
      "tokens/dist/brand-c-crc/",
      "tokens/dist/brand-c-gn/",
      "tokens/dist/brand-c-fmla/"
    ]
  },
  "components": [
    {
      "name": "Button",
      "slug": "button",
      "category": "molecule",
      "spec": "specs/button.spec.md",
      "referenceImplementation": "reference/components/ds/button/",
      "figmaUrl": "https://www.figma.com/design/VFBn7KCDy3FSIlvhNo3ylq/ComPsych-Design-System---Core-Components?node-id=17-1332",
      "status": "ready"
    },
    {
      "name": "Card",
      "slug": "card",
      "category": "molecule",
      "spec": "specs/card.spec.md",
      "referenceImplementation": "reference/components/ds/card/",
      "figmaUrl": "https://www.figma.com/design/VFBn7KCDy3FSIlvhNo3ylq/ComPsych-Design-System---Core-Components?node-id=1117-9829",
      "status": "ready"
    }
  ]
}
